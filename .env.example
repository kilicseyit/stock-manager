# =========================================================================
# StockManager Environment Variables Template / Çevre Değişkenleri Şablonu
# =========================================================================
#
# Copy this file to '.env' and fill in your local or production credentials.
# Bu dosyayı '.env' adıyla kopyalayıp yerel veya üretim ayarlarınızı girin.

# -------------------------------------------------------------------------
# 1. Database Configuration / Veritabanı Yapılandırması
# -------------------------------------------------------------------------
# PostgreSQL connection string for Prisma ORM.
# Prisma ORM için PostgreSQL bağlantı adresi.
# Format: postgresql://[user]:[password]@[host]:[port]/[database_name]?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stockmanager?schema=public"

# -------------------------------------------------------------------------
# 2. Redis Configuration / Redis Yapılandırması
# -------------------------------------------------------------------------
# Redis server connection URL for background jobs (BullMQ queues).
# Arka plan işleri (BullMQ kuyrukları) için Redis sunucu bağlantı adresi.
# Format: redis://[host]:[port] or rediss://[host]:[port] for TLS
REDIS_URL="redis://localhost:6379"

# -------------------------------------------------------------------------
# 3. Authentication Configuration / Kimlik Doğrulama Yapılandırması
# -------------------------------------------------------------------------
# The canonical base URL of your web application. Used for authentication redirect flows.
# Web uygulamanızın ana URL adresi. Yönlendirmeler ve kimlik doğrulama akışlarında kullanılır.
# Local development default: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# Secret key used to sign and encrypt session tokens. Must be a secure 32+ character string.
# Session token'larını imzalamak ve şifrelemek için kullanılan gizli anahtar. En az 32 karakterli güvenli bir string olmalıdır.
# You can generate a strong secret using: openssl rand -base64 33
# Şu komutla güçlü bir anahtar üretebilirsiniz: openssl rand -base64 33
AUTH_SECRET="generate-a-very-long-and-secure-random-secret-key"
NEXTAUTH_SECRET="generate-a-very-long-and-secure-random-secret-key"